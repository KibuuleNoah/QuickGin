





{
  "name": "quickgin-web",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run css:watch\" \"npm run js:watch\"",
    "build": "npm run css:build && npm run js:build",
    "js:build": "node -e \"require('esbuild').buildSync({entryPoints:['src/ts/app.ts'], bundle: true, outfile: 'dist/app.js'})\"",
    "js:watch": "node -e \"require('esbuild').context({ entryPoints: ['src/ts/app.ts'], outfile: 'dist/app.js', bundle: true }).then(ctx => ctx.watch())\"",
    "css:build": "tailwindcss -i src/css/app.css -o dist/app.css --minify",
    "css:watch": "tailwindcss -i src/css/app.css -o dist/app.css --watch"
  },
  "dependencies": {
    "@alpinejs/morph": "^3.14.9",
    "@alpinejs/persist": "^3.14.9",
    "alpinejs": "^3.14.9"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.0",
    "concurrently": "^9.1.2",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.0",
    "typescript": "~5.9.3"
  }
}
